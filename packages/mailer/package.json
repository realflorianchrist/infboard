{
  "name": "@workspace/mailer",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && pnpm run copy:templates",
    "copy:templates": "cp -R src/templates dist/templates"
  },
  "dependencies": {
    "@workspace/types": "workspace:*",
    "handlebars": "^4.7.8",
    "html-to-text": "^9.0.5",
    "jet-logger": "^2.0.1",
    "mjml": "^4.15.3",
    "nodemailer": "^7.0.5"
  },
  "devDependencies": {
    "@types/html-to-text": "^9.0.4",
    "@types/mjml": "^4.7.4",
    "@types/nodemailer": "^7.0.0",
    "typescript": "^5.8.3",
    "tsx": "^4.20.5"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
