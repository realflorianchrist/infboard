<mjml>
    <mj-head>
        <mj-include path="./styles/styles.css" type="css"/>
    </mj-head>
    <mj-body css-class="body">
        <mj-section>
            <mj-column>
                <mj-text>
                    header
                </mj-text>
            </mj-column>
        </mj-section>

        {{{children}}}

        <mj-section>
            <mj-column>
                <mj-text>
                    &copy; Infboard {{year}}
                </mj-text>
            </mj-column>
        </mj-section>
    </mj-body>
</mjml>