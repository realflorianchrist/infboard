{
  "name": "backend",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.prod.json && tsc-alias -p tsconfig.prod.json",
    "clean": "pnpm store prune && rm -rf node_modules dist",
    "docker:up": "docker compose -f docker-compose.local.yml up -d",
    "dev": "pnpm docker:up && tsx watch src/index.ts",
    "lint": "eslint .",
    "start": "NODE_ENV=production tsx dist/index.js",
    "test": "NODE_ENV=test vitest",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1047.0",
    "@aws-sdk/s3-request-presigner": "^3.1047.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@workspace/constants": "workspace:*",
    "@workspace/mailer": "workspace:*",
    "@workspace/routes": "workspace:*",
    "@workspace/types": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "inserturlparams": "^2.0.5",
    "jet-logger": "^2.2.3",
    "jet-paths": "^1.1.0",
    "jsonfile": "^6.2.1",
    "jsonwebtoken": "^9.0.3",
    "module-alias": "^2.3.4",
    "mongodb": "^6.21.0",
    "mongoose": "^8.24.0",
    "mongoose-lean-virtuals": "^2.1.0",
    "morgan": "^1.10.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@swc/core": "^1.15.33",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/find": "^0.2.4",
    "@types/fs-extra": "^11.0.4",
    "@types/jsonfile": "^6.1.4",
    "@types/module-alias": "^2.0.4",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.12.4",
    "@types/supertest": "^6.0.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.4",
    "eslint-plugin-n": "^17.24.0",
    "find": "^0.3.0",
    "fs-extra": "^11.3.5",
    "jiti": "^2.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.2.4"
  },
  "turbo": {
    "outputs": [
      "dist/**"
    ]
  }
}
