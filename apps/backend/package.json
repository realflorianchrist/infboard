{
  "name": "backend",
  "version": "0.0.0",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias",
    "clean": "pnpm store prune && rm -rf node_modules dist",
    "docker:up": "docker compose -f docker-compose.local.yml up -d",
    "dev": "pnpm docker:up && nodemon --watch ./src --ext ts --exec \"ts-node -r tsconfig-paths/register ./src/index.ts\"",
    "lint": "eslint .",
    "start": "NODE_ENV=production node -r dotenv/config dist/apps/backend/src/index.js",
    "test": "NODE_ENV=test vitest",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.844.0",
    "@aws-sdk/s3-request-presigner": "^3.844.0",
    "@workspace/routes": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^17.0.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "inserturlparams": "^2.0.5",
    "jet-logger": "^2.0.1",
    "jet-paths": "^1.1.0",
    "jsonfile": "^6.1.0",
    "module-alias": "^2.2.3",
    "mongodb": "^6.17.0",
    "mongoose": "^8.16.1",
    "morgan": "^1.10.0",
    "tsconfig-paths": "^4.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@swc/core": "^1.12.9",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/find": "^0.2.4",
    "@types/fs-extra": "^11.0.4",
    "@types/jsonfile": "^6.1.4",
    "@types/module-alias": "^2.0.4",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.0.10",
    "@types/supertest": "^6.0.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/types": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.30.1",
    "eslint-plugin-n": "^17.21.0",
    "find": "^0.3.0",
    "fs-extra": "^11.3.0",
    "jiti": "^2.4.2",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  },
  "turbo": {
    "outputs": [
      "dist/**"
    ]
  }
}
