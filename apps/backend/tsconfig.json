{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "baseUrl": "./",
    "moduleResolution": "node",
    "outDir": "dist",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true,
    "useUnknownInCatchVariables": false,
    "paths": {
      "@src/*": ["src/*"],
      "@workspace/types/*": ["../../packages/types/*"],
      "@workspace/routes/*": ["../../packages/routes/*"]
    },
    "types": ["vitest/globals"]
  },
  "ts-node": {
    "swc": true,
    "require": ["tsconfig-paths/register"]
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "scripts",
    "eslint.config.js",
    "vitest.config.mts",
  ],
  "exclude": [
    "src/public/*"
  ]
}
