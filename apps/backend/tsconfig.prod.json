{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "removeComments": true,
    "sourceMap": false,
    "esModuleInterop": true,
    "isolatedModules": false
  },
  "include": [
    "src/**/*.ts",
  ],
  "exclude": [
    "tests",
    "src/public/",
    "scripts",
    "eslint.config.js",
    "vitest.config.mjs"
  ]
}
